{
  "enabled": true,
  "logLevel": "info",

  "connection": {
    "type": "${DVI_SYNC_TYPE:-local}",
    "basePath": "${DVI_SYNC_LOCAL_PATH:-/Volumes/visdir}",
    "host": "${DVI_SYNC_HOST:-192.168.0.27}",
    "port": 445,
    "user": "${DVI_SYNC_USER:-dvi}",
    "password": "${DVI_SYNC_PASSWORD:-dvi}",
    "domain": "${DVI_SYNC_DOMAIN:-WORKGROUP}"
  },

  "syncs": [
    {
      "id": "breakage",
      "name": "Breakage Reports (LDS)",
      "enabled": true,
      "source": {
        "share": "visdir",
        "path": "VISION\\LDS\\breakage"
      },
      "dest": "./data/dvi/breakage",
      "action": "copy",
      "patterns": ["*.txt"],
      "pollInterval": 60000,
      "archiveSource": false
    },
    {
      "id": "jobs",
      "name": "Job Export (XML/JSON)",
      "enabled": true,
      "source": {
        "share": "visdir",
        "path": "VISION\\Q\\jobexport"
      },
      "dest": "./data/dvi/jobs",
      "action": "copy",
      "patterns": ["*.xml", "*.json"],
      "pollInterval": 30000,
      "processJson": true,
      "processXml": true,
      "note": "should be move — needs delete permission on DVI share"
    },
    {
      "id": "daily_export",
      "name": "Daily Job Export",
      "enabled": true,
      "source": {
        "share": "visdir",
        "path": "EXPORT\\D"
      },
      "dest": "./data/dvi/daily",
      "action": "copy",
      "patterns": ["*.txt"],
      "pollInterval": 300000
    },
    {
      "id": "shipped",
      "name": "Shipped Invoices (XML)",
      "enabled": true,
      "source": {
        "share": "visdir",
        "path": "VISION\\SHIPLOG"
      },
      "dest": "./data/dvi/shipped",
      "action": "copy",
      "patterns": ["*.xml"],
      "pollInterval": 60000,
      "archiveDest": true,
      "note": "should be move — needs delete permission on DVI share"
    }
  ],

  "processing": {
    "onJobXml": "parseAndStore",
    "onJobJson": "applyChanges",
    "onShippedXml": "archiveAndNotify",
    "onBreakage": "importReport"
  },

  "notifications": {
    "slack": {
      "enabled": false,
      "channel": "#lab-alerts",
      "onError": true,
      "onShipped": false
    }
  },

  "retry": {
    "maxAttempts": 3,
    "delayMs": 5000,
    "backoffMultiplier": 2
  }
}
