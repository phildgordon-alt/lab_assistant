<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.paireyewear.labassistant.dvimount</string>
    <key>ProgramArguments</key>
    <array>
        <string>/sbin/mount_smbfs</string>
        <string>//dvi:dvi@192.168.0.27/visdir</string>
        <string>/Users/Shared/lab_assistant/data/dvi/mount</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>StandardErrorPath</key>
    <string>/Users/Shared/lab_assistant/server/data/dvimount-error.log</string>
    <key>StandardOutPath</key>
    <string>/Users/Shared/lab_assistant/server/data/dvimount.log</string>
</dict>
</plist>
